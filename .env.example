# Supabase Credentials (from Dashboard -> Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# PayPal Credentials (from Developer Dashboard -> Apps & Credentials)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id

# Admin Access
ADMIN_PASSWORD=clowand888

# Cloudflare R2 — image upload backend (used by /api/upload-image)
# Get from: Cloudflare Dashboard -> R2 -> Manage R2 API Tokens
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_R2_ACCESS_KEY_ID=your-r2-access-key-id
CF_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
CF_R2_PUBLIC_URL=https://pub-xxx.r2.dev
